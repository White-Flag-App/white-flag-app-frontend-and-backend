    <!-- Crypto Price Ticker (Dexscreener Memecoin Feed) -->
    <div class="crypto-ticker">
        <div class="ticker-track" id="tickerTrack">
            <!-- Loading state -->
            <div class="ticker-loading" id="tickerLoading">
                <div class="ticker-loading-spinner"></div>
                <span>Loading trending tokens…</span>
            </div>
            <!-- Error state (hidden by default) -->
            <div class="ticker-error" id="tickerError" style="display:none;">
                <span>⚠️ Failed to load token data</span>
                <button class="ticker-error-retry" onclick="fetchTickerData()">Retry</button>
            </div>
            <!-- Ticker items populated dynamically by JS -->
        </div>
    </div>
