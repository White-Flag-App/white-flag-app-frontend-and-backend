<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>

    <link rel="stylesheet" href="/css/whiteflag.css">

    <!-- ethers.js v6 for EVM wallet support -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.13.4/ethers.umd.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <!-- Solana web3.js for transaction signing -->
    <script src="https://cdn.jsdelivr.net/npm/@solana/web3.js@1/lib/index.iife.min.js" crossorigin="anonymous"></script>
</head>
<body>
    <%- include('partials/ticker') %>

    <!-- Main Content Area -->
    <div class="main-container">
        <%- include('partials/header') %>
        <%- include('partials/screens/feed') %>
        <%- include('partials/screens/following') %>
        <%- include('partials/screens/profile') %>
        <%- include('partials/screens/voicecall') %>
        <%- include('partials/screens/verification') %>
        <%- include('partials/screens/messages') %>
        <%- include('partials/screens/conversation') %>
        <%- include('partials/screens/settings') %>
        <%- include('partials/screens/bookmarks') %>
        <%- include('partials/screens/leaderboard') %>
        <%- include('partials/screens/createvoice') %>
        <%- include('partials/screens/chatroom') %>
    </div>

    <script src="/js/app.js"></script>
    <%- include('partials/modals/voice') %>

    <!-- Loading Spinner -->
    <div class="loading-spinner"></div>

    <script src="/js/pwa.js"></script>
    <script src="/js/api.js"></script>

    <%- include('partials/modals/all') %>

    <script src="/js/gif.js"></script>
</body>
</html>
